# AGRODATA Environment Variables
# Copy this file to .env and fill in your Supabase project credentials.
# Find these values in your Supabase project: Settings -> API

# Your Supabase project URL (e.g. https://xxxxxxxx.supabase.co)
VITE_SUPABASE_URL=

# Your Supabase anon/public key (safe to expose in the browser; protected by RLS)
VITE_SUPABASE_ANON_KEY=
